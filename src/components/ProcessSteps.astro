---
const steps = [
  { num: "01", title: "Operational Audit", desc: "See exactly where time, money, and clarity are being lost." },
  { num: "02", title: "Role Architecture", desc: "Define who owns what, with zero ambiguity." },
  { num: "03", title: "Workflow Blueprint", desc: "Design the future-state operation." },
  { num: "04", title: "Bottleneck Removal", desc: "Eliminate redundancies and friction points." },
  { num: "05", title: "Systems Alignment", desc: "Match your tools to your processes." },
  { num: "06", title: "Technology Integration", desc: "Automate and augment where it creates real value." },
  { num: "07", title: "Team Training", desc: "Structured onboarding into new systems and AI tools." },
  { num: "08", title: "Adoption Reinforcement", desc: "Embed accountability so changes actually hold." },
  { num: "09", title: "Performance Measurement", desc: "Scorecards and metrics that track what matters." },
];
---

<section class="bg-[var(--color-dark)]">
  <div class="section section-inner">
    <div class="text-center max-w-[700px] mx-auto mb-16 md:mb-20">
      <p class="eyebrow mb-4 reveal">Our Method</p>
      <h2
        class="reveal text-[var(--color-text-bright)]"
        style="font-size: clamp(30px, 3.5vw, 44px); font-weight: 700; transition-delay: 0.1s;"
      >
        A proven system. Not a generic playbook.
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-stagger>
      {steps.map((step) => (
        <div
          class="reveal-stagger group rounded-xl p-7 transition-all duration-300 hover:bg-[var(--color-surface-light)] border border-transparent hover:border-[var(--color-border)] hover:-translate-y-1 cursor-default"
          style="background: var(--color-surface-card);"
          onmouseenter="this.style.boxShadow='0 8px 30px rgba(0,0,0,0.3)'"
          onmouseleave="this.style.boxShadow='none'"
        >
          <span class="text-[13px] font-bold uppercase tracking-[1.5px] text-[var(--color-accent)] mb-3 block">
            Step {step.num}
          </span>
          <h3 class="text-lg font-bold text-[var(--color-text-bright)] mb-2" style="font-family: var(--font-heading);">
            {step.title}
          </h3>
          <p class="text-sm leading-relaxed text-[var(--color-text-light)]">
            {step.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
