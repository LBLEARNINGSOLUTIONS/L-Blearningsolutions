---
import { clients } from '../data/clients';
---

<section class="hero-logos border-t border-gray-100">
  <div class="section-inner py-10 md:py-14 px-6 md:px-12">
    <p class="text-center text-xs font-semibold uppercase tracking-[2.5px] text-[var(--color-text-light)] mb-8">
      Trusted by operators across industries
    </p>
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-14">
      {clients.map((client) => (
        <div
          class="flex items-center justify-center h-10 px-5 py-2 rounded-md transition-all duration-400"
          style="filter: grayscale(100%) opacity(0.4);"
          onmouseenter="this.style.filter='grayscale(0%) opacity(1)'"
          onmouseleave="this.style.filter='grayscale(100%) opacity(0.4)'"
        >
          <img
            src={client.logo}
            alt={client.name}
            class="h-8 md:h-10 w-auto object-contain"
            loading="lazy"
            onerror={`this.style.display='none';this.nextElementSibling.style.display='block';`}
          />
          <span
            class="hidden text-sm font-semibold tracking-wide text-[var(--color-dark)] whitespace-nowrap"
            style="font-family: var(--font-body);"
          >
            {client.name}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
