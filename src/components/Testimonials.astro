---
import TestimonialCard from './TestimonialCard.astro';
import { testimonials } from '../data/testimonials';

interface Props {
  useFull?: boolean;
}

const { useFull = false } = Astro.props;
---

<section class="bg-[var(--color-warm-white)] relative noise-overlay-light">
  <div class="section section-inner relative z-10">
    <div class="text-center max-w-[700px] mx-auto mb-16 md:mb-20">
      <p class="eyebrow mb-4 reveal">Client Results</p>
      <h2
        class="reveal"
        style="font-size: clamp(30px, 3.5vw, 44px); font-weight: 700; transition-delay: 0.1s;"
      >
        Don't take our word for it.
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8" data-stagger>
      {testimonials.map((t) => (
        <div class="reveal-stagger">
          <TestimonialCard
            industry={t.industry}
            quote={useFull ? t.quote : t.shortQuote}
            author={t.author}
            role={t.role}
            initials={t.initials}
          />
        </div>
      ))}
    </div>
  </div>
</section>
