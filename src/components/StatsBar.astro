---
const stats = [
  { number: "6+", label: "Industries Served" },
  { number: "$1M–$20M", label: "Client Revenue Range" },
  { number: "100%", label: "Client Retention" },
];
---

<section class="bg-white reveal">
  <div class="section-inner max-w-[900px] py-14 md:py-20 px-6 md:px-12">
    <div class="flex flex-col md:flex-row items-center justify-center divide-y md:divide-y-0 md:divide-x divide-gray-200">
      {stats.map((stat) => (
        <div class="flex flex-col items-center text-center px-8 md:px-12 py-6 md:py-0">
          <span
            class="font-bold text-[var(--color-dark)]"
            style="font-family: var(--font-heading); font-size: clamp(36px, 4vw, 52px); line-height: 1;"
          >
            {stat.number}
          </span>
          <span class="mt-3 text-xs font-semibold uppercase tracking-[2px] text-[var(--color-text-light)]">
            {stat.label}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
