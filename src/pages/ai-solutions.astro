---
import Layout from '../layouts/Layout.astro';
import FinalCTA from '../components/FinalCTA.astro';

const services = [
  {
    num: "01",
    title: "AI Audit & Roadmap",
    desc: "We go inside your operations and assess every workflow, tool, and role to identify exactly where AI creates real value — and where it doesn't. No generic recommendations. You get a prioritized roadmap tailored to your business, your team's readiness, and your budget. This is where every AI engagement starts.",
  },
  {
    num: "02",
    title: "Managed AI Agents",
    desc: "We build custom AI agents that work inside your business — handling project management, client communication, document generation, scheduling, analysis, and more. Then we manage them for you. Your team gets the output without needing to become AI experts. Think of it as hiring a digital employee that we train, deploy, and maintain on your behalf.",
  },
  {
    num: "03",
    title: "AI Training & Adoption",
    desc: "We train your team to use AI tools with confidence — not just how to prompt ChatGPT, but how to integrate AI into their actual daily workflows. From leadership to frontline staff, we build structured training programs that drive real adoption. Our C.O.R.E. framework ensures the training sticks long after we leave.",
  },
  {
    num: "04",
    title: "AI-Powered Automation",
    desc: "We identify repetitive, time-consuming tasks across your operations and automate them — using tools like Power Automate, custom scripts, and AI-driven workflows. Invoice processing, data entry, report generation, scheduling, follow-ups — if your team is doing it manually and it follows a pattern, we can automate it.",
  },
  {
    num: "05",
    title: "Custom App & Tool Building",
    desc: "When off-the-shelf tools don't fit, we build custom. From internal dashboards and project management apps to client-facing tools and estimating software, we design and develop solutions tailored to how your business actually operates. Built to integrate with your existing systems, not replace them.",
  },
];

const processSteps = [
  { num: "01", title: "AI Audit", desc: "We assess your operations, tools, and workflows to find where AI fits." },
  { num: "02", title: "Strategy & Build", desc: "We design the solution, build the agents or automations, and configure everything." },
  { num: "03", title: "Train & Deploy", desc: "We train your team, roll out the tools, and ensure smooth adoption." },
  { num: "04", title: "Manage & Optimize", desc: "We monitor performance, handle maintenance, and optimize over time." },
];

const checklist = [
  "Your team is curious about AI but nobody owns it",
  "You've tried a few tools but nothing stuck",
  "You want AI to save your team real hours, not just sound impressive",
  "You'd rather have experts build and manage it than figure it out yourself",
];

const afterItems = [
  "Repetitive tasks handled automatically — no human bottleneck",
  "Your team uses AI daily with confidence, not confusion",
  "Custom agents handle project management, reporting, and communication",
  "You see exactly what AI saves you — measured in hours and dollars",
  "You have an AI partner on call, not a tool you're trying to figure out alone",
];
---

<Layout
  title="AI Solutions | L&B Learning Solutions"
  description="We become your AI department — auditing where AI fits, building and managing agents, training your team, and automating workflows. Applied AI that saves time and sharpens output."
>
  {/* Hero */}
  <section class="bg-white">
    <div class="section section-inner py-20 md:py-28 lg:py-32">
      <div class="max-w-[800px]">
        <p class="eyebrow mb-6 hero-eyebrow">
          <span class="accent-dot">AI Solutions</span>
        </p>
        <h1
          class="mb-6 hero-headline-line"
          style="font-size: clamp(36px, 4.5vw, 56px); font-weight: 700; line-height: 1.1;"
        >
          <span>Stop Wondering What AI Can Do. Start Seeing It Work.</span>
        </h1>
        <p class="hero-sub text-lg md:text-xl max-w-[640px] mb-10" style="color: var(--color-text-light); line-height: 1.7;">
          Most businesses know AI matters. But between the hype, the tools, and the jargon, it's impossible to know where to start. That's where we come in. We audit your operations, identify where AI creates real leverage, build and manage the tools, and train your team to use them with confidence.
        </p>
        <div class="hero-cta">
          <a href="/contact" class="btn-primary">Book a Free AI Strategy Call →</a>
        </div>
      </div>
    </div>
  </section>

  {/* The Problem */}
  <section class="bg-[var(--color-warm-white)] relative noise-overlay-light">
    <div class="section section-inner relative z-10">
      <h2
        class="mb-16 md:mb-20 reveal"
        style="font-size: clamp(30px, 3.5vw, 44px); font-weight: 700; max-width: 600px;"
      >
        AI is everywhere. Clarity is nowhere.
      </h2>

      <div class="space-y-10 md:space-y-14 max-w-[720px] mb-14">
        <p class="text-xl md:text-2xl font-bold text-[var(--color-dark)] leading-snug reveal" style="font-family: var(--font-heading);">
          Your competitors are adopting AI. You're not sure what they're actually doing with it.
        </p>
        <p class="text-xl md:text-2xl font-bold text-[var(--color-dark)] leading-snug reveal" style="font-family: var(--font-heading); transition-delay: 0.1s;">
          Your team is experimenting with ChatGPT on their own — with no strategy, no guardrails, and no ROI.
        </p>
        <p class="text-xl md:text-2xl font-bold text-[var(--color-dark)] leading-snug reveal" style="font-family: var(--font-heading); transition-delay: 0.2s;">
          You've been pitched AI tools that promise everything and explain nothing.
        </p>
      </div>

      <p class="text-lg text-[var(--color-text-light)] leading-relaxed max-w-[600px] reveal" style="transition-delay: 0.25s;">
        You don't need more AI hype. You need a partner who can cut through the noise, find where AI actually helps your business, and make it work.
      </p>
    </div>
  </section>

  {/* Our AI Services — Accordion */}
  <section class="bg-white">
    <div class="section section-inner">
      <div class="max-w-[800px] mx-auto">
        <p class="eyebrow mb-4 reveal">What We Do</p>
        <h2
          class="mb-14 md:mb-16 reveal"
          style="font-size: clamp(30px, 3.5vw, 44px); font-weight: 700; transition-delay: 0.1s;"
        >
          We become your AI department.
        </h2>

        {services.map((svc, i) => (
          <div class="border-b border-gray-200 reveal" style={`transition-delay: ${Math.min(i * 0.05, 0.25)}s;`}>
            <button
              class="ai-accordion-trigger w-full flex items-center justify-between py-6 md:py-7 text-left group"
              data-index={i}
              aria-expanded={i === 0 ? "true" : "false"}
            >
              <div class="flex items-center gap-5 md:gap-8">
                <span class="text-sm font-bold tracking-[1.5px] text-[var(--color-teal)] min-w-[28px]">
                  {svc.num}
                </span>
                <span
                  class:list={[
                    "text-lg md:text-xl font-bold transition-colors duration-200",
                    i === 0 ? "text-[var(--color-teal)]" : "text-[var(--color-dark)] group-hover:text-[var(--color-teal)]",
                  ]}
                  style="font-family: var(--font-heading);"
                >
                  {svc.title}
                </span>
              </div>
              <span
                class:list={[
                  "accordion-icon text-2xl font-light text-[var(--color-teal)] flex-shrink-0",
                  i === 0 && "open",
                ]}
              >
                +
              </span>
            </button>
            <div class:list={["accordion-content", i === 0 && "open"]}>
              <p class="pb-7 pl-[48px] md:pl-[64px] pr-8 text-[var(--color-text-light)] leading-relaxed max-w-[600px]">
                {svc.desc}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* How It Works */}
  <section class="relative bg-[var(--color-dark)] noise-overlay overflow-hidden">
    <div
      class="absolute top-0 right-0 w-[50%] h-full pointer-events-none"
      style="background: radial-gradient(circle at top right, rgba(13,115,119,0.12) 0%, transparent 60%);"
    ></div>

    <div class="section section-inner relative z-10">
      <div class="text-center max-w-[700px] mx-auto mb-16">
        <p class="eyebrow mb-4 reveal">The Process</p>
        <h2
          class="text-white reveal"
          style="font-size: clamp(30px, 3.5vw, 44px); font-weight: 700; transition-delay: 0.1s;"
        >
          From Audit to Adoption in 30 Days
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12" data-stagger>
        {processSteps.map((step) => (
          <div class="reveal-stagger text-center p-6 md:p-8">
            <span
              class="block text-4xl font-bold mb-4 text-[var(--color-teal)]"
              style="font-family: var(--font-heading);"
            >
              {step.num}
            </span>
            <h3 class="text-white text-lg font-bold mb-3" style="font-family: var(--font-heading);">
              {step.title}
            </h3>
            <p class="text-white/50 text-sm leading-relaxed">
              {step.desc}
            </p>
          </div>
        ))}
      </div>

      <p class="text-center text-white/50 text-sm reveal">
        Most clients see measurable time savings within the first two weeks of deployment.
      </p>
    </div>
  </section>

  {/* Who This Is For */}
  <section class="bg-white">
    <div class="section section-inner">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div class="reveal">
          <p class="eyebrow mb-4">Is This for You?</p>
          <h2 class="mb-6" style="font-size: clamp(28px, 3.5vw, 40px); font-weight: 700;">
            Built for businesses that know AI matters — but don't know where to start.
          </h2>
          <p class="text-[var(--color-text-light)] text-lg leading-relaxed mb-8">
            You don't need to understand AI. You need a partner who does. We work with companies doing $1M–$20M who want to modernize their operations with AI but don't have the in-house expertise to do it themselves.
          </p>
          <ul class="space-y-4">
            {checklist.map((item) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-[var(--color-teal)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-[var(--color-text)] leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="reveal" style="transition-delay: 0.15s;">
          <div class="rounded-xl p-8 md:p-10 border border-gray-200" style="background: var(--color-warm-white);">
            <h3 class="text-lg font-bold text-[var(--color-dark)] mb-6" style="font-family: var(--font-heading);">
              After AI Integration:
            </h3>
            <ul class="space-y-4">
              {afterItems.map((item) => (
                <li class="flex items-start gap-3">
                  <svg class="w-4 h-4 mt-1.5 flex-shrink-0 text-[var(--color-teal)]" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M10 17l5-5-5-5v10z" />
                  </svg>
                  <span class="text-[15px] text-[var(--color-text)] leading-relaxed">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FinalCTA
    variant="teal"
    headline="Your Competitors Won't Wait. Neither Should You."
    body="Book a free AI strategy call. We'll assess where AI fits in your business and show you what's possible — with zero jargon and zero pressure."
    ctaLabel="Book Your Free AI Strategy Call →"
  />
</Layout>

<script>
  function initAIAccordion() {
    const triggers = document.querySelectorAll('.ai-accordion-trigger');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const content = trigger.nextElementSibling as HTMLElement;
        const icon = trigger.querySelector('.accordion-icon') as HTMLElement;
        const title = trigger.querySelector('span:nth-child(2)') as HTMLElement;
        const isOpen = content.classList.contains('open');

        triggers.forEach((t) => {
          const c = t.nextElementSibling as HTMLElement;
          const ic = t.querySelector('.accordion-icon') as HTMLElement;
          const ti = t.querySelector('span:nth-child(2)') as HTMLElement;
          if (c) c.classList.remove('open');
          if (ic) ic.classList.remove('open');
          if (ti) ti.style.color = '';
          t.setAttribute('aria-expanded', 'false');
        });

        if (!isOpen) {
          content.classList.add('open');
          icon.classList.add('open');
          if (title) title.style.color = 'var(--color-teal)';
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  initAIAccordion();
  document.addEventListener('astro:after-swap', initAIAccordion);
</script>
