---
import Layout from '../layouts/Layout.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { testimonials } from '../data/testimonials';
---

<Layout
  title="Results | L&B Learning Solutions"
  description="See how we've modernized operations across trucking, insurance, veterinary, real estate, and more. Real client stories, real results."
>
  {/* Hero */}
  <section class="bg-white">
    <div class="section section-inner py-20 md:py-28 lg:py-32">
      <div class="max-w-[800px]">
        <p class="eyebrow mb-6 hero-eyebrow">
          <span class="accent-dot">Client Results</span>
        </p>
        <h1
          class="mb-6 hero-headline-line"
          style="font-size: clamp(36px, 4.5vw, 56px); font-weight: 700; line-height: 1.1;"
        >
          <span>Real Results. Real Businesses. No Fluff.</span>
        </h1>
        <p class="hero-sub text-lg md:text-xl max-w-[640px]" style="color: var(--color-text-light); line-height: 1.7;">
          We've modernized operations across trucking, insurance, veterinary, real estate, and more. Here's what our clients say.
        </p>
      </div>
    </div>
  </section>

  {/* Client Stories */}
  <section class="bg-[var(--color-warm-white)] relative noise-overlay-light">
    <div class="section section-inner relative z-10">
      <div class="grid gap-8 max-w-[900px] mx-auto" data-stagger>
        {testimonials.map((t) => (
          <div class="reveal-stagger">
            <TestimonialCard
              industry={t.industry}
              quote={t.quote}
              author={t.author}
              role={t.role}
              initials={t.initials}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <FinalCTA
    headline="Your business could be next."
    body=""
    ctaLabel="Book a Free Strategy Call →"
  />
</Layout>
