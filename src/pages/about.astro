---
import Layout from '../layouts/Layout.astro';
import FinalCTA from '../components/FinalCTA.astro';

const founders = [
  {
    name: "Ben Woestman",
    title: "Partner",
    initials: "BW",
    photo: "/ben-headshot.jpg",
    bio: "Ben is the architect behind L&B's operational audits and workflow redesigns. He holds a Master's in Instructional Design from Purdue University, but his real education came from years inside businesses where smart people were stuck in bad systems. He specializes in making the invisible visible—mapping how work actually moves through a company and rebuilding it for clarity and speed.",
  },
  {
    name: "Lyden Egbert",
    title: "Partner",
    initials: "LE",
    photo: "/lyden-headshot.jpg",
    bio: "Lyden leads L&B's AI integration practice and performance consulting engagements. With a Master's from Purdue University and deep expertise in business systems, he brings a builder's mentality to every engagement. He doesn't just identify problems—he designs the solution, trains the team, and stays until it sticks. His focus: making businesses run like they were engineered to, not like they evolved by accident.",
  },
];
---

<Layout
  title="About | L&B Learning Solutions"
  description="L&B was built by operators, not academics. Meet the team behind the business modernization firm helping $1M–$20M companies scale."
>
  {/* Hero */}
  <section>
    <div class="section section-inner py-20 md:py-28 lg:py-32">
      <div class="max-w-[800px]">
        <p class="eyebrow mb-6 hero-eyebrow">
          <span class="accent-dot">About Us</span>
        </p>
        <h1
          class="mb-6 hero-headline-line text-[var(--color-text-bright)]"
          style="font-size: clamp(36px, 4.5vw, 56px); font-weight: 700; line-height: 1.1;"
        >
          <span>We've Sat Where You Sit.</span>
        </h1>
        <p class="hero-sub text-lg md:text-xl max-w-[640px]" style="color: var(--color-text); line-height: 1.7;">
          L&B was built by operators, not academics. We started this firm because we saw too many businesses stuck—great people trapped inside broken systems.
        </p>
      </div>
    </div>
  </section>

  {/* Founder Bios */}
  <section class="bg-[var(--color-surface)] relative noise-overlay">
    <div class="section section-inner relative z-10">
      <div class="space-y-20 md:space-y-28">
        {founders.map((founder, i) => (
          <div
            class:list={[
              "grid md:grid-cols-2 gap-10 md:gap-16 items-center reveal",
              i % 2 === 1 && "md:[direction:rtl]",
            ]}
            style={`transition-delay: ${i * 0.1}s;`}
          >
            {/* Photo Placeholder */}
            <div class={i % 2 === 1 ? "md:[direction:ltr]" : ""}>
              <div class="relative">
                <img
                  src={founder.photo}
                  alt={founder.name}
                  class="w-full aspect-[4/5] object-cover rounded-2xl"
                  loading="lazy"
                  onerror={`this.style.display='none';this.nextElementSibling.style.display='flex';`}
                />
                <div
                  class="hidden aspect-[4/5] rounded-2xl items-center justify-center"
                  style="background: linear-gradient(135deg, #1A1A24 0%, #15151E 100%);"
                >
                  <span
                    class="text-5xl font-bold text-white/60"
                    style="font-family: var(--font-heading);"
                  >
                    {founder.initials}
                  </span>
                </div>
              </div>
            </div>

            {/* Bio */}
            <div class={i % 2 === 1 ? "md:[direction:ltr]" : ""}>
              <p class="eyebrow mb-3">{founder.title}</p>
              <h2
                class="mb-6 text-[var(--color-text-bright)]"
                style="font-size: clamp(28px, 3vw, 36px); font-weight: 700;"
              >
                {founder.name}
              </h2>
              <p class="text-[var(--color-text-light)] text-lg leading-relaxed">
                {founder.bio}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Our Approach */}
  <section class="bg-[var(--color-dark)]">
    <div class="section section-inner">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div class="reveal">
          <h2
            class="mb-6 text-[var(--color-text-bright)]"
            style="font-size: clamp(30px, 3.5vw, 44px); font-weight: 700;"
          >
            Most consulting gets it backward.
          </h2>
        </div>
        <div class="reveal" style="transition-delay: 0.1s;">
          <p class="text-lg leading-relaxed text-[var(--color-text-light)] mb-6">
            Most consultants start with a framework and try to fit your business into it. We start inside your business—watching how work actually moves, listening to your team, and identifying what's broken or outdated. Then we rebuild it.
          </p>
          <p class="text-lg leading-relaxed text-[var(--color-text-light)] mb-6">
            We integrate AI where it creates real leverage — not as a buzzword, but as embedded tools your team actually uses. We don't hand you a report and wish you luck.
          </p>
          <p class="text-lg leading-relaxed text-[var(--color-text)] font-medium">
            We implement the changes, train your team, manage your AI systems, and stay until the new way of working holds. That's the difference between advice and transformation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <FinalCTA
    headline="Ready to work with us?"
    body=""
    ctaLabel="Book a Free Strategy Call →"
  />
</Layout>
